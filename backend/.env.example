# CORS — comma-separated list of allowed frontend origins.
# Dev default (used if unset): http://localhost:5173
# Prod example: https://kpi.example.com
CORS_ORIGIN=http://localhost:5173

# SMTP (monthly report emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
REPORT_EMAIL=
